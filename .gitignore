# Build artifacts
*.o
*.elf
*.bin
*.lst
*.32x

# Track only the current build artifacts in rom/. Old timestamped builds stay
# on disk but untracked; GitHub Releases are the canonical archive.
!rom/backrooms.32x
!rom/md_start.bin

# macOS
.DS_Store
sh_src/md_start.bin

# GCC -MMD auto-generated header dependency files
*.d

# Build version stamp — regenerated every build by the Makefile
sh_src/version.h

# Debug capture artifacts (snapshotted to share with reviewers, not history)
screenshots/

# Blender intermediate files — regenerated by scripts/genbox.py et al.
scripts/*.blend
scripts/*.blend1

# Third-party / reference 3D source assets — kept on disk, not ours to track.
models/

# images/: track only the ones the asset bakers actually consume; reference
# and unused art stays on disk but untracked.
images/*
!images/neanderthal.png
!images/splash_label.png
!images/square_walltile_composite.jpg
!images/walltile.jpg
# Canonical design reference (the HobbyTown photo the whole look is based on).
!images/HobbyTown_USA_Oshkosh_interior_under_construction_2002_(The_Backrooms).jpg
!images/outlet.jpg
